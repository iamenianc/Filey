<Window x:Class="Filey.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Rename" Height="160" Width="350"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">
    <Border Background="#1E1E1E" 
            BorderBrush="#2D2D2D" 
            BorderThickness="1" 
            CornerRadius="8"
            Padding="16"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" 
                       Text="Rename" 
                       Foreground="#FFFFFF" 
                       FontSize="{DynamicResource TitleFontSize}" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,12"/>

            <!-- Input -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <ui:TextBox x:Name="NameTextBox" 
                            Padding="8,6" 
                            FontSize="{DynamicResource NormalFontSize}"
                            KeyDown="NameTextBox_KeyDown"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,12,0,0">
                <ui:Button x:Name="CancelButton" 
                           Content="Cancel" 
                           Click="CancelButton_Click" 
                           Width="75" 
                           Height="26" 
                           Appearance="Secondary"
                           Margin="0,0,8,0"/>
                <ui:Button x:Name="RenameBtn" 
                           Content="Rename" 
                           Click="RenameBtn_Click" 
                           Width="75" 
                           Height="26" 
                           Appearance="Primary"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
