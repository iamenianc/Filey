<UserControl x:Class="Filey.AddressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Filey"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="600">
    <UserControl.Resources>
        <!-- Breadcrumb specific Button Style -->
        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- Style for the PathTextBox to match theme and prevent white background on focus -->
        <Style x:Key="PathTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active/Last Segment Text Color -->
        <SolidColorBrush x:Key="BreadcrumbActiveTextBrush" Color="{DynamicResource AppTextPrimaryColor}"/>
        <!-- Chevron Color -->
        <SolidColorBrush x:Key="BreadcrumbChevronBrush" Color="{DynamicResource AppTextSecondaryColor}"/>
    </UserControl.Resources>

    <Border Margin="0,0,0,8"
            Background="{DynamicResource AppPanelBackgroundBrush}"
            CornerRadius="6"
            Padding="6,5,6,5">
        <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <!-- Back Button -->
            <ColumnDefinition Width="Auto"/>
            <!-- Forward Button -->
            <ColumnDefinition Width="Auto"/>
            <!-- Home Button -->
            <ColumnDefinition Width="Auto"/>
            <!-- Spacer -->
            <ColumnDefinition Width="4"/>
            <!-- Address Bar Box -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Back Button -->
        <Button Grid.Column="0" 
                Width="30" 
                Height="30" 
                Style="{StaticResource FlatButtonStyle}"
                ToolTip="Back"
                IsEnabled="{Binding CanGoBack, RelativeSource={RelativeSource AncestorType=local:AddressBar}}"
                Click="BackButton_Click">
            <Path Width="10" 
                  Height="10" 
                  Stretch="Uniform" 
                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                  StrokeThickness="1.5" 
                  StrokeStartLineCap="Round" 
                  StrokeEndLineCap="Round" 
                  StrokeLineJoin="Round"
                  Data="M 6,2 L 2,5 L 6,8 M 2,5 L 8,5"/>
        </Button>

        <!-- Forward Button -->
        <Button Grid.Column="1" 
                Width="30" 
                Height="30" 
                Style="{StaticResource FlatButtonStyle}"
                ToolTip="Forward"
                IsEnabled="{Binding CanGoForward, RelativeSource={RelativeSource AncestorType=local:AddressBar}}"
                Click="ForwardButton_Click">
            <Path Width="10" 
                  Height="10" 
                  Stretch="Uniform" 
                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                  StrokeThickness="1.5" 
                  StrokeStartLineCap="Round" 
                  StrokeEndLineCap="Round" 
                  StrokeLineJoin="Round"
                  Data="M 4,2 L 8,5 L 4,8 M 8,5 L 2,5"/>
        </Button>

        <!-- Home Button: left-click navigates to this pane's Home, right-click sets it -->
        <Button Grid.Column="2"
                Width="30"
                Height="30"
                Style="{StaticResource FlatButtonStyle}"
                ToolTip="Home (right-click to set this pane's Home folder)"
                Click="HomeButton_Click"
                MouseRightButtonUp="HomeButton_RightClick">
            <Path Width="11"
                  Height="11"
                  Stretch="Uniform"
                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                  StrokeThickness="1.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  Data="M 2,5 L 6,1.5 L 10,5 M 3,4.2 L 3,9.5 L 9,9.5 L 9,4.2"/>
        </Button>

        <!-- Main Bar Area -->
        <Border x:Name="MainBarBorder"
                Grid.Column="4"
                Background="{DynamicResource AppPanelDeepBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Height="32">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Mode host: breadcrumbs / path-edit / search all occupy this cell -->
                <Grid Grid.Column="0">
                    <!-- Breadcrumbs Mode (Visible by Default) -->
                    <Border x:Name="BreadcrumbsWrapper"
                            Background="Transparent"
                            MouseLeftButtonDown="BreadcrumbsWrapper_MouseLeftButtonDown"
                            SizeChanged="BreadcrumbsWrapper_SizeChanged"
                            Padding="6,0,6,0">
                        <StackPanel x:Name="BreadcrumbsContainer"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"/>
                    </Border>

                    <!-- Edit Mode (Hidden by Default) -->
                    <Grid x:Name="EditModeGrid" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PathTextBox"
                                 Grid.Column="0"
                                 Style="{StaticResource PathTextBoxStyle}"
                                 Padding="8,0,8,0"
                                 FontFamily="{DynamicResource AppMonoFontFamily}"
                                 FontSize="12"
                                 KeyDown="TextBox_KeyDown"
                                 LostFocus="TextBox_LostFocus"
                                 TextChanged="TextBox_TextChanged"/>

                        <!-- Error Text Block placed inside the Address Bar on the right -->
                        <TextBlock x:Name="ErrorTextBlock"
                                   Grid.Column="1"
                                   Foreground="{DynamicResource AppErrorBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed"/>
                    </Grid>

                    <!-- Search Mode (Hidden by Default) -->
                    <Grid x:Name="SearchModeGrid" Visibility="Collapsed">
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource PathTextBoxStyle}"
                                 Padding="8,0,8,0"
                                 FontSize="12"
                                 KeyDown="SearchTextBox_KeyDown"
                                 TextChanged="SearchTextBox_TextChanged"
                                 LostKeyboardFocus="Search_LostKeyboardFocus"/>
                        <TextBlock x:Name="SearchPlaceholder"
                                   Text="Search indexed files and folders…"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Opacity="0.5"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    </Grid>
                </Grid>

                <!-- Search activate / close toggle at the right end of the bar -->
                <Button x:Name="SearchToggleButton"
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        Margin="2,0,2,0"
                        Style="{StaticResource FlatButtonStyle}"
                        ToolTip="Search indexed files (click to type)"
                        Click="SearchToggleButton_Click">
                    <Grid Width="14" Height="14">
                        <Ellipse Width="9" Height="9"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                 StrokeThickness="1.5"/>
                        <Line X1="8.5" Y1="8.5" X2="13" Y2="13"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Grid>
                </Button>

                <!-- Search results dropdown, anchored under the bar -->
                <Popup x:Name="SearchResultsPopup"
                       PlacementTarget="{Binding ElementName=MainBarBorder}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       Width="{Binding ActualWidth, ElementName=MainBarBorder}">
                    <Border Background="{DynamicResource AppPanelBackgroundBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            MaxHeight="360"
                            Margin="0,2,0,0">
                        <ListBox x:Name="SearchResultsList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MouseDoubleClick="SearchResultsList_MouseDoubleClick"
                                 KeyDown="SearchResultsList_KeyDown"
                                 LostKeyboardFocus="Search_LostKeyboardFocus">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,2">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FullPath}" FontSize="10" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>
        </Border>
        </Grid>
    </Border>
</UserControl>
