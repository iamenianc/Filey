<ui:FluentWindow
    x:Class="Filey.PreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Filey"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="File Preview"
    Height="700"
    Width="1300"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <ui:TitleBar
            Grid.Row="0"
            Title="File Preview"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True" />

        <!-- Mode 1: Text Viewer -->
        <TextBox
            x:Name="ContentTextBox"
            Grid.Row="1"
            Visibility="Collapsed"
            Background="#1E1E1E"
            Foreground="#D4D4D4"
            BorderThickness="0"
            FontFamily="Consolas"
            FontSize="13"
            Padding="12"
            IsReadOnly="True"
            AcceptsReturn="True"
            AcceptsTab="True"
            TextWrapping="Wrap"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            CaretBrush="#E0E0E0"
            SelectionBrush="#094771"
            PreviewMouseWheel="ContentTextBox_PreviewMouseWheel" />

        <!-- Mode 2: Image Viewer -->
        <ScrollViewer
            x:Name="ImageScrollViewer"
            Grid.Row="1"
            Visibility="Collapsed"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Background="#1E1E1E"
            PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
            <Grid
                x:Name="ImageGrid"
                Background="Transparent"
                ClipToBounds="True"
                MouseLeftButtonDown="ImageGrid_MouseLeftButtonDown"
                MouseLeftButtonUp="ImageGrid_MouseLeftButtonUp"
                MouseMove="ImageGrid_MouseMove">
                <Image
                    x:Name="ContentImage"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.LayoutTransform>
                        <TransformGroup>
                            <ScaleTransform
                                x:Name="ImageScale" />
                            <RotateTransform
                                x:Name="ImageRotation" />
                        </TransformGroup>
                    </Image.LayoutTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Mode 3: PDF Viewer -->
        <ScrollViewer
            x:Name="PdfActiveViewer"
            Grid.Row="1"
            Visibility="Collapsed"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            ScrollChanged="PdfActiveViewer_ScrollChanged"
            SizeChanged="PdfActiveViewer_SizeChanged">
            <ItemsControl
                x:Name="PdfPageItemsControl"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="8,12"
                            BorderBrush="#2D2D2D"
                            BorderThickness="1"
                            Background="#1E1E1E"
                            Width="{Binding DisplayWidth}"
                            Height="{Binding DisplayHeight}"
                            HorizontalAlignment="Center">
                            <Grid>
                                <TextBlock
                                    Text="Loading..."
                                    Foreground="#555555"
                                    FontSize="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style
                                            TargetType="TextBlock">
                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Image}"
                                                    Value="{x:Null}">
                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Image
                                    Source="{Binding Image}"
                                    Stretch="Uniform"
                                    RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border
            Grid.Row="2"
            Background="#1B1B1B"
            BorderBrush="#2D2D2D"
            BorderThickness="0,1,0,0"
            Height="28"
            Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PathTextBlock"
                    Grid.Column="0"
                    Foreground="#858585"
                    FontSize="11"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <TextBlock
                    x:Name="EncodingTextBlock"
                    Grid.Column="1"
                    Foreground="#858585"
                    FontSize="11"
                    VerticalAlignment="Center"
                    Margin="24,0,0,0" />

                <TextBlock
                    x:Name="SizeTextBlock"
                    Grid.Column="2"
                    Foreground="#858585"
                    FontSize="11"
                    VerticalAlignment="Center"
                    Margin="24,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
