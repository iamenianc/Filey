<Window
    x:Class="Filey.PreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Filey"
    mc:Ignorable="d"
    Title="File Preview"
    Height="700"
    Width="1300"
    Background="#121212"
    Foreground="#E0E0E0"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Mode 1: Text Viewer -->
        <TextBox
            x:Name="ContentTextBox"
            Grid.Row="0"
            Visibility="Collapsed"
            Background="#1E1E1E"
            Foreground="#D4D4D4"
            BorderThickness="0"
            FontFamily="Consolas"
            FontSize="13"
            Padding="12"
            IsReadOnly="True"
            AcceptsReturn="True"
            AcceptsTab="True"
            TextWrapping="NoWrap"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            CaretBrush="#E0E0E0"
            SelectionBrush="#094771"
            PreviewMouseWheel="ContentTextBox_PreviewMouseWheel" />

        <!-- Mode 2: Image Viewer -->
        <ScrollViewer
            x:Name="ImageScrollViewer"
            Grid.Row="0"
            Visibility="Collapsed"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Background="#1E1E1E"
            PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
            <Grid
                x:Name="ImageGrid"
                Background="Transparent"
                ClipToBounds="True"
                MouseLeftButtonDown="ImageGrid_MouseLeftButtonDown"
                MouseLeftButtonUp="ImageGrid_MouseLeftButtonUp"
                MouseMove="ImageGrid_MouseMove">
                <Image
                    x:Name="ContentImage"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.LayoutTransform>
                        <TransformGroup>
                            <ScaleTransform
                                x:Name="ImageScale" />
                            <RotateTransform
                                x:Name="ImageRotation" />
                        </TransformGroup>
                    </Image.LayoutTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border
            Grid.Row="1"
            Background="#1B1B1B"
            BorderBrush="#2D2D2D"
            BorderThickness="0,1,0,0"
            Height="28"
            Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PathTextBlock"
                    Grid.Column="0"
                    Foreground="#858585"
                    FontSize="11"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <TextBlock
                    x:Name="EncodingTextBlock"
                    Grid.Column="1"
                    Foreground="#858585"
                    FontSize="11"
                    VerticalAlignment="Center"
                    Margin="24,0,0,0" />

                <TextBlock
                    x:Name="SizeTextBlock"
                    Grid.Column="2"
                    Foreground="#858585"
                    FontSize="11"
                    VerticalAlignment="Center"
                    Margin="24,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</Window>
