<ui:FluentWindow
    x:Class="Filey.PreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Filey"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="File Preview"
    Height="700"
    Width="1300"
    WindowState="Maximized"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <ui:TitleBar
            Grid.Row="0"
            Title="File Preview"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True" />

        <!-- PDF Control Toolbar -->
        <Border
            x:Name="PdfToolbarBorder"
            Grid.Row="1"
            Background="#1B1B1B"
            BorderBrush="#2D2D2D"
            BorderThickness="0,0,0,1"
            Height="38"
            Visibility="Collapsed">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Sidebar toggle -->
                    <ColumnDefinition Width="Auto" /> <!-- Separator -->
                    <ColumnDefinition Width="Auto" /> <!-- View Layouts (Single vs Dual) -->
                    <ColumnDefinition Width="Auto" /> <!-- Separator -->
                    <ColumnDefinition Width="Auto" /> <!-- Navigation Buttons -->
                    <ColumnDefinition Width="*" />    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" /> <!-- Zoom Controls -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar Toggle -->
                <Button
                    x:Name="SidebarToggleButton"
                    Grid.Column="0"
                    Content="📋 Sidebar"
                    Click="SidebarToggleButton_Click"
                    Background="#2D2D2D"
                    Foreground="#E0E0E0"
                    BorderThickness="0"
                    Padding="8,4"
                    FontSize="{DynamicResource HeaderFontSize}"
                    Cursor="Hand" />

                <Border Grid.Column="1" Background="#2D2D2D" Width="1" Margin="8,8" />

                <!-- Single vs Dual Page Toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                    <RadioButton
                        x:Name="SinglePageRadio"
                        Content="📄 Single"
                        GroupName="LayoutModeGroup"
                        IsChecked="True"
                        Checked="LayoutModeRadio_Checked"
                        Style="{StaticResource ToggleTabRadioButtonStyle}"
                        Margin="0,0,4,0" />
                    <RadioButton
                        x:Name="DualPageRadio"
                        Content="👥 Dual Spread"
                        GroupName="LayoutModeGroup"
                        Checked="LayoutModeRadio_Checked"
                        Style="{StaticResource ToggleTabRadioButtonStyle}" />
                </StackPanel>

                <Border Grid.Column="3" Background="#2D2D2D" Width="1" Margin="8,8" />

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button
                        x:Name="PrevPageButton"
                        Content="◀ Prev"
                        Click="PrevPageButton_Click"
                        Background="#2D2D2D"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Padding="8,4"
                        FontSize="{DynamicResource HeaderFontSize}"
                        Cursor="Hand" />
                    <TextBlock
                        x:Name="PageIndicatorText"
                        Text="Page 1 of 1"
                        Foreground="#A0A0A0"
                        FontSize="{DynamicResource HeaderFontSize}"
                        VerticalAlignment="Center"
                        Margin="10,0" />
                    <Button
                        x:Name="NextPageButton"
                        Content="Next ▶"
                        Click="NextPageButton_Click"
                        Background="#2D2D2D"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Padding="8,4"
                        FontSize="{DynamicResource HeaderFontSize}"
                        Cursor="Hand" />
                </StackPanel>

                <!-- Zoom Controls -->
                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button
                        x:Name="ZoomOutButton"
                        Content="➖"
                        Click="ZoomOutButton_Click"
                        Background="#2D2D2D"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Padding="8,4"
                        FontSize="{DynamicResource HeaderFontSize}"
                        Cursor="Hand" />
                    <TextBlock
                        x:Name="ZoomText"
                        Text="100%"
                        Width="45"
                        TextAlignment="Center"
                        Foreground="#A0A0A0"
                        FontSize="{DynamicResource HeaderFontSize}"
                        VerticalAlignment="Center"
                        Margin="4,0" />
                    <Button
                        x:Name="ZoomInButton"
                        Content="➕"
                        Click="ZoomInButton_Click"
                        Background="#2D2D2D"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Padding="8,4"
                        FontSize="{DynamicResource HeaderFontSize}"
                        Cursor="Hand" />
                    <Button
                        x:Name="FitWidthButton"
                        Content="↔ Width"
                        Click="FitWidthButton_Click"
                        Background="#2D2D2D"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Padding="8,4"
                        FontSize="{DynamicResource HeaderFontSize}"
                        Margin="6,0,0,0"
                        Cursor="Hand" />
                    <Button
                        x:Name="FitPageButton"
                        Content="↕ Page"
                        Click="FitPageButton_Click"
                        Background="#2D2D2D"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Padding="8,4"
                        FontSize="{DynamicResource HeaderFontSize}"
                        Margin="4,0,0,0"
                        Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Mode 1: Text Viewer -->
        <TextBox
            x:Name="ContentTextBox"
            Grid.Row="2"
            Visibility="Collapsed"
            Background="#1E1E1E"
            Foreground="#D4D4D4"
            BorderThickness="0"
            FontFamily="Consolas"
            FontSize="{DynamicResource NormalFontSize}"
            Padding="12"
            IsReadOnly="True"
            AcceptsReturn="True"
            AcceptsTab="True"
            TextWrapping="Wrap"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            CaretBrush="#E0E0E0"
            SelectionBrush="#094771"
            PreviewMouseWheel="ContentTextBox_PreviewMouseWheel" />

        <!-- Mode 2: Image Viewer -->
        <ScrollViewer
            x:Name="ImageScrollViewer"
            Grid.Row="2"
            Visibility="Collapsed"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Background="#1E1E1E"
            PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
            <Grid
                x:Name="ImageGrid"
                Background="Transparent"
                ClipToBounds="True"
                MouseLeftButtonDown="ImageGrid_MouseLeftButtonDown"
                MouseLeftButtonUp="ImageGrid_MouseLeftButtonUp"
                MouseMove="ImageGrid_MouseMove">
                <Image
                    x:Name="ContentImage"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.LayoutTransform>
                        <TransformGroup>
                            <ScaleTransform
                                x:Name="ImageScale" />
                            <RotateTransform
                                x:Name="ImageRotation" />
                        </TransformGroup>
                    </Image.LayoutTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Mode 3: PDF Viewer Container Grid -->
        <Grid
            x:Name="PdfViewerGrid"
            Grid.Row="2"
            Visibility="Collapsed"
            Background="#1E1E1E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" x:Name="PdfSidebarColumn" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Collapsible Left Sidebar (Thumbnails + Page Navigation) -->
            <Border
                x:Name="PdfSidebarBorder"
                Grid.Column="0"
                Background="#161616"
                BorderBrush="#2D2D2D"
                BorderThickness="0,0,1,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Go to page section -->
                        <RowDefinition Height="*" />    <!-- Thumbnails list -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Go to page:" Foreground="#858585" FontSize="{DynamicResource HeaderFontSize}" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PdfPageJumpInput" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#2D2D2D" FontSize="{DynamicResource HeaderFontSize}" Padding="4" Height="24" KeyDown="PdfPageJumpInput_KeyDown"/>
                            <Button Grid.Column="1" Content="Go" Width="40" Margin="4,0,0,0" Height="24" Click="PdfPageJumpButton_Click" Background="#2D2D2D" Foreground="#E0E0E0" FontSize="{DynamicResource HeaderFontSize}" BorderThickness="0" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>

                    <!-- Page Thumbnails List -->
                    <ScrollViewer
                        Grid.Row="1"
                        x:Name="PdfThumbnailScrollViewer"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl
                            x:Name="PdfThumbnailItemsControl"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling"
                            VirtualizingStackPanel.CacheLengthUnit="Page"
                            VirtualizingStackPanel.CacheLength="2,2">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Margin="0,6"
                                        Padding="4"
                                        Background="Transparent"
                                        BorderBrush="#2D2D2D"
                                        BorderThickness="1"
                                        Click="ThumbnailButton_Click"
                                        HorizontalAlignment="Center"
                                        Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#2D2D2D"/>
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#094771"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <Grid>
                                            <Border Background="#101010" Width="100" Height="{Binding ThumbnailHeight}">
                                                <Image Source="{Binding ThumbnailImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality"/>
                                            </Border>
                                            <Border Background="#80000000" VerticalAlignment="Bottom" HorizontalAlignment="Right" Padding="4,2" CornerRadius="2,0,0,0">
                                                <TextBlock Text="{Binding PageNumber}" Foreground="#E0E0E0" FontSize="{DynamicResource SmallFontSize}"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Main PDF Viewer -->
            <ScrollViewer
                Grid.Column="1"
                x:Name="PdfActiveViewer"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                ScrollChanged="PdfActiveViewer_ScrollChanged"
                PreviewMouseWheel="PdfActiveViewer_PreviewMouseWheel">
                <ItemsControl
                    x:Name="PdfPageItemsControl"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ItemsControl.LayoutTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="PdfScale" />
                        </TransformGroup>
                    </ItemsControl.LayoutTransform>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Row representing either one single page or two pages side-by-side -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                                <!-- Left Page -->
                                <Border
                                    Margin="8,0"
                                    BorderBrush="#2D2D2D"
                                    BorderThickness="1"
                                    Background="#1E1E1E"
                                    Width="{Binding LeftPageWidth}"
                                    Height="{Binding DisplayHeight}"
                                    HorizontalAlignment="Center">
                                    <Grid>
                                        <TextBlock
                                            Text="Loading..."
                                            Foreground="#555555"
                                            FontSize="{DynamicResource NormalFontSize}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style
                                                    TargetType="TextBlock">
                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding LeftPageImage}"
                                                            Value="{x:Null}">
                                                            <Setter
                                                                Property="Visibility"
                                                                Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Image
                                            Source="{Binding LeftPageImage}"
                                            Stretch="Uniform"
                                            RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>
                                </Border>

                                <!-- Right Page (Only visible in Dual Mode) -->
                                <Border
                                    Margin="8,0"
                                    BorderBrush="#2D2D2D"
                                    BorderThickness="1"
                                    Background="#1E1E1E"
                                    Width="{Binding RightPageWidth}"
                                    Height="{Binding DisplayHeight}"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding RightPageVisibility}">
                                    <Grid>
                                        <TextBlock
                                            Text="Loading..."
                                            Foreground="#555555"
                                            FontSize="{DynamicResource NormalFontSize}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style
                                                    TargetType="TextBlock">
                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding RightPageImage}"
                                                            Value="{x:Null}">
                                                            <Setter
                                                                Property="Visibility"
                                                                Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Image
                                            Source="{Binding RightPageImage}"
                                            Stretch="Uniform"
                                            RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border
            Grid.Row="3"
            Background="#1B1B1B"
            BorderBrush="#2D2D2D"
            BorderThickness="0,1,0,0"
            Height="28"
            Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PathTextBlock"
                    Grid.Column="0"
                    Foreground="#858585"
                    FontSize="{DynamicResource HeaderFontSize}"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <TextBlock
                    x:Name="EncodingTextBlock"
                    Grid.Column="1"
                    Foreground="#858585"
                    FontSize="{DynamicResource HeaderFontSize}"
                    VerticalAlignment="Center"
                    Margin="24,0,0,0" />

                <TextBlock
                    x:Name="SizeTextBlock"
                    Grid.Column="2"
                    Foreground="#858585"
                    FontSize="{DynamicResource HeaderFontSize}"
                    VerticalAlignment="Center"
                    Margin="24,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
