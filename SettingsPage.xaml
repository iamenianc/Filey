<Page x:Class="Filey.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Filey"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Settings"
      Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- Settings Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">

                <!-- Theme Section -->
                <TextBlock Text="Appearance" Foreground="{DynamicResource AppTextSecondaryBrush}"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                
                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Background="{DynamicResource AppPanelBackgroundBrush}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="App Theme" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" FontSize="14"/>
                            <TextBlock Text="Select between Light and Dark application themes" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton x:Name="ThemeToggleControl"
                                      Grid.Column="1"
                                      Style="{StaticResource TopBarToggleStyle}"
                                      Content="Theme: Dark"
                                      VerticalAlignment="Center"
                                      Checked="ThemeToggleControl_Changed"
                                      Unchecked="ThemeToggleControl_Changed"/>
                    </Grid>
                </Border>

                <!-- Layout Section -->
                <TextBlock Text="Explorer Options" Foreground="{DynamicResource AppTextSecondaryBrush}"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Background="{DynamicResource AppPanelBackgroundBrush}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Right Pane Mode -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Right Pane View Mode" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="Configure right side layout as hidden, preview panel, or dual directory pane" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button x:Name="RightPaneOffButton" Content="Off" Width="75" Height="30"
                                           Margin="0,0,6,0" Click="RightPaneOffButton_Click"/>
                                <ui:Button x:Name="RightPanePreviewButton" Content="Preview" Width="75" Height="30"
                                           Margin="0,0,6,0" Click="RightPanePreviewButton_Click"/>
                                <ui:Button x:Name="RightPaneDualButton" Content="Dual" Width="75" Height="30"
                                           Click="RightPaneDualButton_Click"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="{DynamicResource AppBorderBrush}" Margin="0,0,0,16"/>

                        <!-- Compact mode -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Compact View" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="Reduce row spacing inside the directory listings for higher density" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="CompactModeToggleControl"
                                          Grid.Column="1"
                                          Style="{StaticResource TopBarToggleStyle}"
                                          Content="Compact"
                                          VerticalAlignment="Center"
                                          Checked="CompactModeToggleControl_Changed"
                                          Unchecked="CompactModeToggleControl_Changed"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Folders Section -->
                <TextBlock Text="Home Locations" Foreground="{DynamicResource AppTextSecondaryBrush}"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Background="{DynamicResource AppPanelBackgroundBrush}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Left Home path -->
                        <TextBlock Text="Left Pane Home Path" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" FontSize="14" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="LeftHomePathBox" Grid.Column="0"
                                        IsReadOnly="True" Padding="8,6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ui:Button Grid.Column="1" Content="Browse…" Width="90" Height="32"
                                       Click="BrowseLeftHomeButton_Click" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Right Home path -->
                        <TextBlock Text="Right Pane Home Path" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" FontSize="14" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="RightHomePathBox" Grid.Column="0"
                                        IsReadOnly="True" Padding="8,6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ui:Button Grid.Column="1" Content="Browse…" Width="90" Height="32"
                                       Click="BrowseRightHomeButton_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
