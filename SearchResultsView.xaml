<UserControl x:Class="Filey.SearchResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Filey"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="900"
             x:Name="self">
    <Border Background="{DynamicResource AppPanelBackgroundBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="3">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header strip: title, query, result count, close -->
            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    MinHeight="34"
                    Padding="8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Search results"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource AppTextPrimaryBrush}">
                        <Run Text="“"/><Run x:Name="QueryRun" FontWeight="SemiBold"/><Run Text="” — "/><Run x:Name="CountRun"/>
                    </TextBlock>

                    <Button Grid.Column="2"
                            Style="{StaticResource FlatButtonStyle}"
                            Width="26" Height="26"
                            ToolTip="Close search results (Esc)"
                            Click="CloseButton_Click">
                        <Path Width="10" Height="10" Stretch="Uniform"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 1,1 L 9,9 M 9,1 L 1,9"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Dense, rank-ordered result rows -->
            <ui:ListView x:Name="ResultsListView"
                         Grid.Row="1"
                         Style="{StaticResource ModernListView}"
                         GridViewColumnHeader.Click="Header_Click"
                         KeyDown="ResultsListView_KeyDown"
                         MouseDoubleClick="ResultsListView_MouseDoubleClick">
                <ui:ListView.ItemContainerStyle>
                    <Style TargetType="ui:ListViewItem" BasedOn="{StaticResource {x:Type ui:ListViewItem}}">
                        <Setter Property="Padding" Value="4,1,4,1"/>
                    </Style>
                </ui:ListView.ItemContainerStyle>
                <ui:ListView.View>
                    <GridView>
                        <GridViewColumn Width="44">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="#" Tag="Rank"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Rank}"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,6,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AppTextDimBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="260">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Name" Tag="Name"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="340" DisplayMemberBinding="{Binding ParentFolder}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Location" Tag="ParentFolder"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn Width="90" DisplayMemberBinding="{Binding Type}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Type" Tag="Type"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn Width="140" DisplayMemberBinding="{Binding DateModifiedFormatted}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Date Modified" Tag="DateModified"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn Width="85" DisplayMemberBinding="{Binding SizeFormatted}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Size" Tag="Size"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                    </GridView>
                </ui:ListView.View>
            </ui:ListView>

            <!-- Empty / busy status -->
            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Visibility="Collapsed"/>

            <!-- Footer hint -->
            <Border Grid.Row="2"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,3">
                <TextBlock Text="Enter or double-click to open · Esc to close · click a column to re-sort"
                           Foreground="{DynamicResource AppTextDimBrush}"
                           FontSize="11"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
