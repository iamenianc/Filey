<UserControl
    x:Class="Filey.Previews.PdfPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Grid>
        <!-- Preview State: 2x2 Grid for the first 4 pages -->
        <Grid
            x:Name="PdfSkimGrid"
            Visibility="Visible"
            Focusable="True"
            MouseDown="PdfSkimGrid_MouseDown">
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="*" />
                <RowDefinition
                    Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="*" />
                <ColumnDefinition
                    Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="PdfSkimBorder0"
                Grid.Row="0"
                Grid.Column="0"
                Margin="4"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource AppSurfaceDarkBrush}">
                <Image
                    x:Name="PdfSkimImage0"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>
            <Border
                x:Name="PdfSkimBorder1"
                Grid.Row="0"
                Grid.Column="1"
                Margin="4"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource AppSurfaceDarkBrush}">
                <Image
                    x:Name="PdfSkimImage1"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>
            <Border
                x:Name="PdfSkimBorder2"
                Grid.Row="1"
                Grid.Column="0"
                Margin="4"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource AppSurfaceDarkBrush}">
                <Image
                    x:Name="PdfSkimImage2"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>
            <Border
                x:Name="PdfSkimBorder3"
                Grid.Row="1"
                Grid.Column="1"
                Margin="4"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource AppSurfaceDarkBrush}">
                <Image
                    x:Name="PdfSkimImage3"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <!-- Overlay prompt -->
            <Border
                Grid.Row="0"
                Grid.Column="0"
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                Background="#B00C0C0C"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="16"
                Padding="12,6"
                IsHitTestVisible="False">
                <TextBlock
                    Text="🖱️ Double-click to open in full preview window"
                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                    FontSize="{DynamicResource HeaderFontSize}"
                    FontWeight="SemiBold" />
            </Border>
        </Grid>

        <!-- Active State: Full scroll viewer -->
        <ScrollViewer
            x:Name="PdfActiveViewer"
            Visibility="Collapsed"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            ScrollChanged="PdfActiveViewer_ScrollChanged"
            SizeChanged="PdfActiveViewer_SizeChanged">
            <ItemsControl
                x:Name="PdfPageItemsControl"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="8,12"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource AppPanelBackgroundBrush}"
                            Width="{Binding DisplayWidth}"
                            Height="{Binding DisplayHeight}"
                            HorizontalAlignment="Center"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <TextBlock
                                    Text="Loading..."
                                    Foreground="{DynamicResource AppTextDimBrush}"
                                    FontSize="{DynamicResource NormalFontSize}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style
                                            TargetType="TextBlock">
                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Image}"
                                                    Value="{x:Null}">
                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Image
                                    Source="{Binding Image}"
                                    Stretch="Uniform"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    SnapsToDevicePixels="True" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
