<UserControl
    x:Class="Filey.Previews.FolderPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Filey"
    Background="Transparent">
    <ScrollViewer
        x:Name="FolderScrollViewer"
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollBarVisibility="Auto"
        Background="Transparent"
        Padding="16"
        PreviewMouseWheel="FolderScrollViewer_PreviewMouseWheel"
        ScrollChanged="FolderScrollViewer_ScrollChanged">
        <local:FastTreeVisualHost
            x:Name="FolderTreeVisualHost"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" />
    </ScrollViewer>
</UserControl>
