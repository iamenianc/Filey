<UserControl x:Class="Filey.DirectoryPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Filey"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="self">
    <UserControl.Resources>
        <!-- Shared right-click context menu for all folder/file items in this pane -->
        <ContextMenu x:Key="ItemContextMenu" Opened="ItemContextMenu_Opened">
            <MenuItem
                x:Name="CtxPreviewItem"
                Header="Preview"
                Click="CtxPreview_Click" />
            <MenuItem Header="Open in Windows Explorer" Click="CtxOpenExplorer_Click"/>
            <MenuItem Header="Copy path to clipboard" Click="CtxCopyPath_Click"/>
            <MenuItem x:Name="CtxFavouriteItem" Header="Add to Favourites" Click="CtxToggleFavourite_Click"/>
        </ContextMenu>

        <!-- ListBoxItem Style for Folders list -->
        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <EventSetter Event="MouseDoubleClick" Handler="FoldersItem_MouseDoubleClick" />
            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
            <Setter Property="Padding" Value="{DynamicResource RowItemPadding}" />
        </Style>

        <!-- ListViewItem Style for Contents grid -->
        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
            <Setter Property="Padding" Value="{DynamicResource RowItemPadding}" />
        </Style>
    </UserControl.Resources>

    <Grid DataContext="{Binding ViewModel, ElementName=self}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Path Display -->
        <local:AddressBar x:Name="AddressBar"
                          Grid.Row="0"
                          CurrentPath="{Binding CurrentPath}"
                          CanGoBack="{Binding CanGoBack}"
                          CanGoForward="{Binding CanGoForward}"
                          NavigationRequested="AddressBar_NavigationRequested"
                          GoBackRequested="AddressBar_GoBackRequested"
                          GoForwardRequested="AddressBar_GoForwardRequested"
                          HomeRequested="AddressBar_HomeRequested"
                          SetHomeRequested="AddressBar_SetHomeRequested"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Col 0: Folders -->
                <ColumnDefinition x:Name="ParentFoldersCol" Width="150" MinWidth="100"/>
                <!-- Divider -->
                <ColumnDefinition Width="4" />
                <!-- Col 2: Contents -->
                <ColumnDefinition x:Name="ContentsCol" Width="2*" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- Parent Folders Panel -->
            <Border x:Name="ParentFoldersPanel"
                    Grid.Column="0"
                    Background="#1E1E1E"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    CornerRadius="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header strip with Back Icon -->
                    <Border Grid.Row="0"
                            Background="#252526"
                            BorderBrush="#2D2D2D"
                            BorderThickness="0,0,0,1"
                            Height="32"
                            Padding="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ParentBackButton"
                                    Grid.Column="0"
                                    Style="{StaticResource FlatButtonStyle}"
                                    Width="24" Height="24"
                                    ToolTip="Go back in tree"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding CanGoToParent}"
                                    Click="ParentBackButton_Click">
                                <Path Width="8"
                                      Height="8"
                                      Stretch="Uniform"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M 6,2 L 2,5 L 6,8 M 2,5 L 8,5"/>
                            </Button>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ParentFolderName}"
                                       Foreground="#CCCCCC"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="8,0,8,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <!-- Search bar -->
                    <Grid Grid.Row="1" Margin="4,4,4,2">
                        <TextBox x:Name="ParentFoldersSearch"
                                 Background="#121212" Foreground="#E0E0E0" CaretBrush="#E0E0E0"
                                 BorderBrush="#2D2D2D" BorderThickness="1"
                                 Padding="6,3,4,3" VerticalContentAlignment="Center"
                                 TextChanged="ParentFoldersSearch_TextChanged"/>
                        <TextBlock x:Name="ParentFoldersSearchPlaceholder" Text="search…"
                                   Foreground="#666666" Margin="8,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Grid>

                    <!-- ListBox -->
                    <ListBox x:Name="ParentFoldersList" Grid.Row="2"
                             Style="{StaticResource ModernListBox}"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectedItem="{Binding SelectedParentFolder}"
                             KeyDown="List_KeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center" Margin="{DynamicResource RowCellMargin}">
                                    <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                    <TextBox x:Name="NameEdit"
                                             Text="{Binding Name, UpdateSourceTrigger=Explicit}"
                                             Background="#121212"
                                             Foreground="#E0E0E0"
                                             BorderBrush="#007ACC"
                                             BorderThickness="1"
                                             Padding="2,1"
                                             Margin="-2,-2,-2,-2"
                                             Visibility="Collapsed"
                                             LostFocus="NameEdit_LostFocus"
                                             KeyDown="NameEdit_KeyDown"
                                             IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- GridSplitter 1 -->
            <GridSplitter Grid.Column="1" Style="{StaticResource ModernGridSplitter}" />

            <!-- Contents (Split: Top = Folders, Bottom = Files) -->
            <Grid x:Name="ContentsPanel" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="FoldersRow" Height="*" MinHeight="100"/>
                    <RowDefinition x:Name="SplitterRow" Height="6"/>
                    <RowDefinition x:Name="FilesRow" Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Folders (Child Folders) -->
                <ListView x:Name="FoldersListView" Grid.Row="0"
                          Style="{StaticResource ModernListView}"
                          ItemsSource="{Binding Folders}"
                          SelectedItem="{Binding SelectedItem}"
                          GridViewColumnHeader.Click="Header_Click"
                          PreviewMouseLeftButtonDown="ItemList_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="ItemList_PreviewMouseMove"
                          KeyDown="List_KeyDown">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <EventSetter Event="MouseDoubleClick" Handler="ContentsItem_MouseDoubleClick" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="220">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Folders" Tag="Name"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="{DynamicResource RowCellMargin}">
                                            <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                            <Grid VerticalAlignment="Center">
                                                <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                                <TextBox x:Name="NameEdit" 
                                                         Text="{Binding Name, UpdateSourceTrigger=Explicit}" 
                                                         Background="#121212" 
                                                         Foreground="#E0E0E0" 
                                                         BorderBrush="#007ACC" 
                                                         BorderThickness="1" 
                                                         Padding="2,1"
                                                         Margin="-2,-2,-2,-2"
                                                         Visibility="Collapsed"
                                                         LostFocus="NameEdit_LostFocus"
                                                         KeyDown="NameEdit_KeyDown"
                                                         IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                            </Grid>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="130" DisplayMemberBinding="{Binding DateModifiedFormatted}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Date Modified" Tag="DateModified"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="85" DisplayMemberBinding="{Binding SizeFormatted}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Size" Tag="Size"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="100" DisplayMemberBinding="{Binding Type}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Type" Tag="Type"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Horizontal Grid Splitter -->
                <GridSplitter x:Name="GridSplitter" Grid.Row="1" Style="{StaticResource ModernGridSplitter}" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                <!-- Files (Child Files) -->
                <ListView x:Name="FilesListView" Grid.Row="2"
                          Style="{StaticResource ModernListView}"
                          ItemsSource="{Binding Contents}"
                          SelectedItem="{Binding SelectedItem}"
                          GridViewColumnHeader.Click="Header_Click"
                          PreviewMouseLeftButtonDown="ItemList_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="ItemList_PreviewMouseMove"
                          KeyDown="List_KeyDown">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <EventSetter Event="MouseDoubleClick" Handler="ContentsItem_MouseDoubleClick" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="220">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Files" Tag="Name"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="{DynamicResource RowCellMargin}">
                                            <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                            <Grid VerticalAlignment="Center">
                                                <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                                <TextBox x:Name="NameEdit" 
                                                         Text="{Binding Name, UpdateSourceTrigger=Explicit}" 
                                                         Background="#121212" 
                                                         Foreground="#E0E0E0" 
                                                         BorderBrush="#007ACC" 
                                                         BorderThickness="1" 
                                                         Padding="2,1"
                                                         Margin="-2,-2,-2,-2"
                                                         Visibility="Collapsed"
                                                         LostFocus="NameEdit_LostFocus"
                                                         KeyDown="NameEdit_KeyDown"
                                                         IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                            </Grid>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="130" DisplayMemberBinding="{Binding DateModifiedFormatted}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Date Modified" Tag="DateModified"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="85" DisplayMemberBinding="{Binding SizeFormatted}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Size" Tag="Size"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="100" DisplayMemberBinding="{Binding Type}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Type" Tag="Type"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
