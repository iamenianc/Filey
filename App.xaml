<Application x:Class="Filey.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Filey"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <!-- Centralized fonts (theme-independent) and the active color palette.
                     The palette is swapped at runtime by ThemeService; Styles.xaml and all
                     views reference these via DynamicResource so they re-resolve on swap.
                     The palette must sit after the WPF-UI dictionaries (so our keys win) and
                     before Styles.xaml (so styles can resolve our brushes). -->
                <ResourceDictionary Source="Themes/Fonts.xaml"/>
                <ResourceDictionary Source="Themes/Colors.Dark.xaml"/>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Dynamic font size resources -->
            <system:Double x:Key="AppFontSize">11.5</system:Double>
            <system:Double x:Key="NormalFontSize">12.0</system:Double>
            <system:Double x:Key="SmallFontSize">10.0</system:Double>
            <system:Double x:Key="HeaderFontSize">11.0</system:Double>
            <system:Double x:Key="LargeFontSize">16.0</system:Double>
            <system:Double x:Key="TitleFontSize">14.0</system:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
