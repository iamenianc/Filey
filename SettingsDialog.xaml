<Window x:Class="Filey.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings" Height="420" Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">
    <Border Background="{DynamicResource AppPanelBackgroundBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="Settings"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <!-- Settings list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Theme -->
                    <TextBlock Text="Theme" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,4"/>
                    <ToggleButton x:Name="ThemeToggleControl"
                                  Style="{StaticResource TopBarToggleStyle}"
                                  HorizontalAlignment="Left"
                                  Content="Theme: Dark"
                                  Margin="0,0,0,12"
                                  Checked="ThemeToggleControl_Changed"
                                  Unchecked="ThemeToggleControl_Changed"/>

                    <!-- Right pane mode -->
                    <TextBlock Text="Right pane" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:Button x:Name="RightPaneOffButton" Content="Off" Width="70" Height="26"
                                   Margin="0,0,6,0" Click="RightPaneOffButton_Click"/>
                        <ui:Button x:Name="RightPanePreviewButton" Content="Preview" Width="70" Height="26"
                                   Margin="0,0,6,0" Click="RightPanePreviewButton_Click"/>
                        <ui:Button x:Name="RightPaneDualButton" Content="Dual" Width="70" Height="26"
                                   Click="RightPaneDualButton_Click"/>
                    </StackPanel>

                    <!-- Compact mode -->
                    <TextBlock Text="Density" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,4"/>
                    <ToggleButton x:Name="CompactModeToggleControl"
                                  Style="{StaticResource TopBarToggleStyle}"
                                  HorizontalAlignment="Left"
                                  Content="Compact"
                                  Margin="0,0,0,12"
                                  Checked="CompactModeToggleControl_Changed"
                                  Unchecked="CompactModeToggleControl_Changed"/>

                    <!-- Left Home path -->
                    <TextBlock Text="Left pane Home folder" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="LeftHomePathBox" Grid.Column="0"
                                    IsReadOnly="True" Padding="6,4" Margin="0,0,6,0"/>
                        <ui:Button Grid.Column="1" Content="Browse…" Width="75" Height="26"
                                   Click="BrowseLeftHomeButton_Click"/>
                    </Grid>

                    <!-- Right Home path -->
                    <TextBlock Text="Right pane Home folder" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="RightHomePathBox" Grid.Column="0"
                                    IsReadOnly="True" Padding="6,4" Margin="0,0,6,0"/>
                        <ui:Button Grid.Column="1" Content="Browse…" Width="75" Height="26"
                                   Click="BrowseRightHomeButton_Click"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <ui:Button x:Name="CloseButton"
                           Content="Close"
                           Click="CloseButton_Click"
                           Width="75"
                           Height="26"
                           Appearance="Primary"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
