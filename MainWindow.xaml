<ui:FluentWindow x:Class="Filey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Filey"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Filey — Dual Pane File Manager"
        Height="787"
        Width="1555"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content (NavigationView + Frame) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <ui:TitleBar
            Grid.Row="0"
            Title="Filey — Dual Pane File Manager"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True" />

        <!-- Main Layout with NavigationView and Frame -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Shell Navigation -->
            <ui:NavigationView
                x:Name="RootNavigationView"
                Grid.Column="0"
                PaneDisplayMode="LeftCompact"
                IsPaneOpen="False"
                SelectionChanged="RootNavigationView_SelectionChanged">
                
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem
                        x:Name="ExplorerItem"
                        Content="Explorer"
                        Icon="{ui:SymbolIcon Folder24}" />
                    <ui:NavigationViewItem
                        x:Name="IndexerItem"
                        Content="Crawler Status"
                        Icon="{ui:SymbolIcon Database24}" />
                </ui:NavigationView.MenuItems>

                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem
                        x:Name="SettingsItem"
                        Content="Settings"
                        Icon="{ui:SymbolIcon Settings24}" />
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <!-- Main Page Frame -->
            <Frame
                x:Name="RootFrame"
                Grid.Column="1"
                NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
