<Window x:Class="Filey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Filey"
        mc:Ignorable="d"
        Title="Filey — Dual Pane File Manager" Height="787" Width="1555"
        Background="#121212"
        Foreground="#E0E0E0">
    <Window.Resources>
        <!-- Row density values, swapped at runtime by the Compact Mode toggle. -->
        <Thickness x:Key="RowItemPadding">4,4,4,4</Thickness>
        <Thickness x:Key="RowCellMargin">2</Thickness>

        <!-- Shared right-click context menu for all folder/file/bookmark items -->
        <ContextMenu x:Key="ItemContextMenu" Opened="ItemContextMenu_Opened">
            <MenuItem Header="Open in Windows Explorer" Click="CtxOpenExplorer_Click"/>
            <MenuItem Header="Copy path to clipboard" Click="CtxCopyPath_Click"/>
            <MenuItem x:Name="CtxFavouriteItem" Header="Add to Favourites" Click="CtxToggleFavourite_Click"/>
        </ContextMenu>

        <!-- Modern Flat Button Style for Back Navigation in Parent Panel -->
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,4,6,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                CornerRadius="4" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1E1E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim flat toggle button for the top menu bar -->
        <Style x:Key="TopBarToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Grid Splitter Style -->
        <Style x:Key="ModernGridSplitter" TargetType="GridSplitter">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <!-- Modern ListBox Style -->
        <Style x:Key="ModernListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#2D2D2D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <!-- ListBoxItem Style for Folders list -->
        <Style TargetType="ListBoxItem">
            <EventSetter Event="MouseDoubleClick" Handler="FoldersItem_MouseDoubleClick" />
            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="{DynamicResource RowItemPadding}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#094771" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="true" />
                                    <Condition Property="Selector.IsSelectionActive" Value="false" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#094771" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ListView Style -->
        <Style x:Key="ModernListView" TargetType="ListView">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#2D2D2D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Padding="{TemplateBinding Padding}"
                                          Focusable="False">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListViewItem Style for Contents grid -->
        <Style TargetType="ListViewItem">
            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="{DynamicResource RowItemPadding}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true"
                                CornerRadius="3">
                            <GridViewRowPresenter Columns="{TemplateBinding GridView.ColumnCollection}"
                                                 VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#094771" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="true" />
                                    <Condition Property="Selector.IsSelectionActive" Value="false" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#37373D" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for the Column Header Gripper (Resize handle) -->
        <Style x:Key="GridViewColumnHeaderGripper" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Column Header Style -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,8,6,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <Thumb x:Name="PART_HeaderGripper"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,-4,0"
                                   Width="8"
                                   Style="{StaticResource GridViewColumnHeaderGripper}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#2A2D2E" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#252526" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Menu Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Pane Layout -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Global Top Menu Bar: slim container for toggles/buttons added in later patches -->
        <Border x:Name="TopMenuBar"
                Grid.Row="0"
                Background="#1B1B1B"
                BorderBrush="#2D2D2D"
                BorderThickness="0,0,0,1"
                Height="28">
            <StackPanel x:Name="TopMenuBarItems"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="6,0">
                <ToggleButton x:Name="RightPaneToggle"
                              Style="{StaticResource TopBarToggleStyle}"
                              Content="Right Pane"
                              ToolTip="Show or hide the right pane"
                              IsChecked="True"
                              Checked="RightPaneToggle_Changed"
                              Unchecked="RightPaneToggle_Changed"/>
                <ToggleButton x:Name="ShowHiddenToggle"
                              Style="{StaticResource TopBarToggleStyle}"
                              Content="Hidden"
                              ToolTip="Show or hide hidden and system items"
                              Checked="ShowHiddenToggle_Changed"
                              Unchecked="ShowHiddenToggle_Changed"/>
                <ToggleButton x:Name="CompactModeToggle"
                              Style="{StaticResource TopBarToggleStyle}"
                              Content="Compact"
                              ToolTip="Reduce row spacing in the file lists"
                              Checked="CompactModeToggle_Changed"
                              Unchecked="CompactModeToggle_Changed"/>
            </StackPanel>
        </Border>

    <Grid Grid.Row="1" Margin="8">
        <Grid.ColumnDefinitions>
            <!-- Left Side Pane -->
            <ColumnDefinition x:Name="LeftPaneCol" Width="1000" MinWidth="200" />
            <!-- Centre Splitter -->
            <ColumnDefinition x:Name="CentreSplitterCol" Width="12" />
            <!-- Right Side Pane -->
            <ColumnDefinition x:Name="RightPaneCol" Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <!-- Left Pane Grid -->
        <Grid x:Name="LeftPaneGrid" Grid.Column="0" DataContext="{Binding LeftViewModel, RelativeSource={RelativeSource AncestorType=local:MainWindow}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Path Display -->
            <local:AddressBar x:Name="LeftAddressBar"
                              Grid.Row="0"
                              CurrentPath="{Binding CurrentPath}"
                              CanGoBack="{Binding CanGoBack}"
                              CanGoForward="{Binding CanGoForward}"
                              NavigationRequested="AddressBar_NavigationRequested"
                              GoBackRequested="AddressBar_GoBackRequested"
                              GoForwardRequested="AddressBar_GoForwardRequested"
                              HomeRequested="AddressBar_HomeRequested"
                              SetHomeRequested="AddressBar_SetHomeRequested"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Col 0: Favourites L -->
                    <ColumnDefinition x:Name="LeftFavouritesCol" Width="150" MinWidth="50"/>
                    <!-- Divider 1 -->
                    <ColumnDefinition Width="4" />
                    <!-- Col 1: Folders L -->
                    <ColumnDefinition x:Name="LeftParentFoldersCol" Width="150" MinWidth="100"/>
                    <!-- Divider 2 -->
                    <ColumnDefinition Width="4" />
                    <!-- Col 2: Contents L -->
                    <ColumnDefinition x:Name="LeftContentsCol" Width="2*" MinWidth="150"/>
                </Grid.ColumnDefinitions>

                <!-- Favourites L -->
                <local:FavouritesPanel x:Name="LeftFavouritesPanel" Grid.Column="0" Side="Left"/>

                <!-- GridSplitter 1 -->
                <GridSplitter Grid.Column="1" Style="{StaticResource ModernGridSplitter}" />

                <!-- Parent Folders L -->
                <Border x:Name="LeftParentFoldersPanel"
                        Grid.Column="2"
                        Background="#1E1E1E"
                        BorderBrush="#2D2D2D"
                        BorderThickness="1"
                        CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header strip with Back Icon -->
                        <Border Grid.Row="0"
                                Background="#252526"
                                BorderBrush="#2D2D2D"
                                BorderThickness="0,0,0,1"
                                Height="32"
                                Padding="4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="LeftParentBackButton"
                                        Grid.Column="0"
                                        Style="{StaticResource FlatButtonStyle}"
                                        Width="24" Height="24"
                                        ToolTip="Go back in tree"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        IsEnabled="{Binding CanGoToParent}"
                                        Click="ParentBackButton_Click">
                                    <Path Width="8"
                                          Height="8"
                                          Stretch="Uniform"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M 6,2 L 2,5 L 6,8 M 2,5 L 8,5"/>
                                </Button>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ParentFolderName}"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="8,0,8,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>

                        <!-- Search bar -->
                        <Grid Grid.Row="1" Margin="4,4,4,2">
                            <TextBox x:Name="LeftParentFoldersSearch"
                                     Background="#121212" Foreground="#E0E0E0" CaretBrush="#E0E0E0"
                                     BorderBrush="#2D2D2D" BorderThickness="1"
                                     Padding="6,3,4,3" VerticalContentAlignment="Center"
                                     TextChanged="LeftParentFoldersSearch_TextChanged"/>
                            <TextBlock x:Name="LeftParentFoldersSearchPlaceholder" Text="search…"
                                       Foreground="#666666" Margin="8,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>

                        <!-- ListBox -->
                        <ListBox x:Name="LeftParentFoldersList" Grid.Row="2"
                                 Style="{StaticResource ModernListBox}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectedItem="{Binding SelectedParentFolder}"
                                 KeyDown="List_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" Margin="{DynamicResource RowCellMargin}">
                                        <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                        <TextBox x:Name="NameEdit"
                                                 Text="{Binding Name, UpdateSourceTrigger=Explicit}"
                                                 Background="#121212"
                                                 Foreground="#E0E0E0"
                                                 BorderBrush="#007ACC"
                                                 BorderThickness="1"
                                                 Padding="2,1"
                                                 Margin="-2,-2,-2,-2"
                                                 Visibility="Collapsed"
                                                 LostFocus="NameEdit_LostFocus"
                                                 KeyDown="NameEdit_KeyDown"
                                                 IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- GridSplitter 2 -->
                <GridSplitter Grid.Column="3" Style="{StaticResource ModernGridSplitter}" />

                <!-- Contents L (Split: Top = Folders, Bottom = Files) -->
                <Grid Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="LeftFoldersRow" Height="*" MinHeight="100"/>
                        <RowDefinition x:Name="LeftSplitterRow" Height="6"/>
                        <RowDefinition x:Name="LeftFilesRow" Height="*" MinHeight="100"/>
                    </Grid.RowDefinitions>

                    <!-- Folders L (Child Folders) -->
                    <ListView x:Name="LeftFoldersListView" Grid.Row="0"
                              Style="{StaticResource ModernListView}"
                              ItemsSource="{Binding Folders}"
                              SelectedItem="{Binding SelectedItem}"
                              GridViewColumnHeader.Click="Header_Click"
                              PreviewMouseLeftButtonDown="ItemList_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="ItemList_PreviewMouseMove"
                              KeyDown="List_KeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <EventSetter Event="MouseDoubleClick" Handler="ContentsItem_MouseDoubleClick" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="220">
                                    <GridViewColumnHeader Content="Folders" Tag="Name"/>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="{DynamicResource RowCellMargin}">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                                <Grid VerticalAlignment="Center">
                                                    <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                                    <TextBox x:Name="NameEdit" 
                                                             Text="{Binding Name, UpdateSourceTrigger=Explicit}" 
                                                             Background="#121212" 
                                                             Foreground="#E0E0E0" 
                                                             BorderBrush="#007ACC" 
                                                             BorderThickness="1" 
                                                             Padding="2,1"
                                                             Margin="-2,-2,-2,-2"
                                                             Visibility="Collapsed"
                                                             LostFocus="NameEdit_LostFocus"
                                                             KeyDown="NameEdit_KeyDown"
                                                             IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                                </Grid>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="130" DisplayMemberBinding="{Binding DateModifiedFormatted}">
                                    <GridViewColumnHeader Content="Date Modified" Tag="DateModified"/>
                                </GridViewColumn>
                                <GridViewColumn Width="85" DisplayMemberBinding="{Binding SizeFormatted}">
                                    <GridViewColumnHeader Content="Size" Tag="Size"/>
                                </GridViewColumn>
                                <GridViewColumn Width="100" DisplayMemberBinding="{Binding Type}">
                                    <GridViewColumnHeader Content="Type" Tag="Type"/>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Horizontal Grid Splitter -->
                    <GridSplitter x:Name="LeftGridSplitter" Grid.Row="1" Style="{StaticResource ModernGridSplitter}" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                    <!-- Files L (Child Files) -->
                    <ListView x:Name="LeftFilesListView" Grid.Row="2"
                              Style="{StaticResource ModernListView}"
                              ItemsSource="{Binding Contents}"
                              SelectedItem="{Binding SelectedItem}"
                              GridViewColumnHeader.Click="Header_Click"
                              PreviewMouseLeftButtonDown="ItemList_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="ItemList_PreviewMouseMove"
                              KeyDown="List_KeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <EventSetter Event="MouseDoubleClick" Handler="ContentsItem_MouseDoubleClick" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="220">
                                    <GridViewColumnHeader Content="Files" Tag="Name"/>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="{DynamicResource RowCellMargin}">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                                <Grid VerticalAlignment="Center">
                                                    <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                                    <TextBox x:Name="NameEdit" 
                                                             Text="{Binding Name, UpdateSourceTrigger=Explicit}" 
                                                             Background="#121212" 
                                                             Foreground="#E0E0E0" 
                                                             BorderBrush="#007ACC" 
                                                             BorderThickness="1" 
                                                             Padding="2,1"
                                                             Margin="-2,-2,-2,-2"
                                                             Visibility="Collapsed"
                                                             LostFocus="NameEdit_LostFocus"
                                                             KeyDown="NameEdit_KeyDown"
                                                             IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                                </Grid>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="130" DisplayMemberBinding="{Binding DateModifiedFormatted}">
                                    <GridViewColumnHeader Content="Date Modified" Tag="DateModified"/>
                                </GridViewColumn>
                                <GridViewColumn Width="85" DisplayMemberBinding="{Binding SizeFormatted}">
                                    <GridViewColumnHeader Content="Size" Tag="Size"/>
                                </GridViewColumn>
                                <GridViewColumn Width="100" DisplayMemberBinding="{Binding Type}">
                                    <GridViewColumnHeader Content="Type" Tag="Type"/>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <!-- Centre Splitter -->
        <GridSplitter x:Name="CentreSplitter" Grid.Column="1" Style="{StaticResource ModernGridSplitter}" Width="12" />

        <!-- Right Pane Grid -->
        <Grid x:Name="RightPaneGrid" Grid.Column="2" DataContext="{Binding RightViewModel, RelativeSource={RelativeSource AncestorType=local:MainWindow}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Path Display -->
            <local:AddressBar x:Name="RightAddressBar"
                              Grid.Row="0"
                              CurrentPath="{Binding CurrentPath}"
                              CanGoBack="{Binding CanGoBack}"
                              CanGoForward="{Binding CanGoForward}"
                              NavigationRequested="AddressBar_NavigationRequested"
                              GoBackRequested="AddressBar_GoBackRequested"
                              GoForwardRequested="AddressBar_GoForwardRequested"
                              HomeRequested="AddressBar_HomeRequested"
                              SetHomeRequested="AddressBar_SetHomeRequested"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Col 0: Contents R -->
                    <ColumnDefinition x:Name="RightContentsCol" Width="2*" MinWidth="150"/>
                    <!-- Divider 1 -->
                    <ColumnDefinition Width="4" />
                    <!-- Col 1: Folders R -->
                    <ColumnDefinition x:Name="RightParentFoldersCol" Width="150" MinWidth="100"/>
                </Grid.ColumnDefinitions>                <!-- Contents R (Split: Top = Folders, Bottom = Files) -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="RightFoldersRow" Height="*" MinHeight="100"/>
                        <RowDefinition x:Name="RightSplitterRow" Height="6"/>
                        <RowDefinition x:Name="RightFilesRow" Height="*" MinHeight="100"/>
                    </Grid.RowDefinitions>

                    <!-- Folders R (Child Folders) -->
                    <ListView x:Name="RightFoldersListView" Grid.Row="0"
                              Style="{StaticResource ModernListView}"
                              ItemsSource="{Binding Folders}"
                              SelectedItem="{Binding SelectedItem}"
                              GridViewColumnHeader.Click="Header_Click"
                              PreviewMouseLeftButtonDown="ItemList_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="ItemList_PreviewMouseMove"
                              KeyDown="List_KeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <EventSetter Event="MouseDoubleClick" Handler="ContentsItem_MouseDoubleClick" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="220">
                                    <GridViewColumnHeader Content="Folders" Tag="Name"/>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="{DynamicResource RowCellMargin}">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                                <Grid VerticalAlignment="Center">
                                                    <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                                    <TextBox x:Name="NameEdit" 
                                                             Text="{Binding Name, UpdateSourceTrigger=Explicit}" 
                                                             Background="#121212" 
                                                             Foreground="#E0E0E0" 
                                                             BorderBrush="#007ACC" 
                                                             BorderThickness="1" 
                                                             Padding="2,1"
                                                             Margin="-2,-2,-2,-2"
                                                             Visibility="Collapsed"
                                                             LostFocus="NameEdit_LostFocus"
                                                             KeyDown="NameEdit_KeyDown"
                                                             IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                                </Grid>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="130" DisplayMemberBinding="{Binding DateModifiedFormatted}">
                                    <GridViewColumnHeader Content="Date Modified" Tag="DateModified"/>
                                </GridViewColumn>
                                <GridViewColumn Width="85" DisplayMemberBinding="{Binding SizeFormatted}">
                                    <GridViewColumnHeader Content="Size" Tag="Size"/>
                                </GridViewColumn>
                                <GridViewColumn Width="100" DisplayMemberBinding="{Binding Type}">
                                    <GridViewColumnHeader Content="Type" Tag="Type"/>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Horizontal Grid Splitter -->
                    <GridSplitter x:Name="RightGridSplitter" Grid.Row="1" Style="{StaticResource ModernGridSplitter}" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                    <!-- Files R (Child Files) -->
                    <ListView x:Name="RightFilesListView" Grid.Row="2"
                              Style="{StaticResource ModernListView}"
                              ItemsSource="{Binding Contents}"
                              SelectedItem="{Binding SelectedItem}"
                              GridViewColumnHeader.Click="Header_Click"
                              PreviewMouseLeftButtonDown="ItemList_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="ItemList_PreviewMouseMove"
                              KeyDown="List_KeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <EventSetter Event="MouseDoubleClick" Handler="ContentsItem_MouseDoubleClick" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="220">
                                    <GridViewColumnHeader Content="Files" Tag="Name"/>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="{DynamicResource RowCellMargin}">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                                <Grid VerticalAlignment="Center">
                                                    <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                                    <TextBox x:Name="NameEdit" 
                                                             Text="{Binding Name, UpdateSourceTrigger=Explicit}" 
                                                             Background="#121212" 
                                                             Foreground="#E0E0E0" 
                                                             BorderBrush="#007ACC" 
                                                             BorderThickness="1" 
                                                             Padding="2,1"
                                                             Margin="-2,-2,-2,-2"
                                                             Visibility="Collapsed"
                                                             LostFocus="NameEdit_LostFocus"
                                                             KeyDown="NameEdit_KeyDown"
                                                             IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                                </Grid>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="130" DisplayMemberBinding="{Binding DateModifiedFormatted}">
                                    <GridViewColumnHeader Content="Date Modified" Tag="DateModified"/>
                                </GridViewColumn>
                                <GridViewColumn Width="85" DisplayMemberBinding="{Binding SizeFormatted}">
                                    <GridViewColumnHeader Content="Size" Tag="Size"/>
                                </GridViewColumn>
                                <GridViewColumn Width="100" DisplayMemberBinding="{Binding Type}">
                                    <GridViewColumnHeader Content="Type" Tag="Type"/>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>

                <!-- GridSplitter 1 -->
                <GridSplitter Grid.Column="1" Style="{StaticResource ModernGridSplitter}" />

                <!-- Parent Folders R -->
                <Border x:Name="RightParentFoldersPanel"
                        Grid.Column="2"
                        Background="#1E1E1E"
                        BorderBrush="#2D2D2D"
                        BorderThickness="1"
                        CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header strip with Back Icon -->
                        <Border Grid.Row="0"
                                Background="#252526"
                                BorderBrush="#2D2D2D"
                                BorderThickness="0,0,0,1"
                                Height="32"
                                Padding="4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="RightParentBackButton"
                                        Grid.Column="0"
                                        Style="{StaticResource FlatButtonStyle}"
                                        Width="24" Height="24"
                                        ToolTip="Go back in tree"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        IsEnabled="{Binding CanGoToParent}"
                                        Click="ParentBackButton_Click">
                                    <Path Width="8"
                                          Height="8"
                                          Stretch="Uniform"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M 6,2 L 2,5 L 6,8 M 2,5 L 8,5"/>
                                </Button>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ParentFolderName}"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="8,0,8,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>

                        <!-- Search bar -->
                        <Grid Grid.Row="1" Margin="4,4,4,2">
                            <TextBox x:Name="RightParentFoldersSearch"
                                     Background="#121212" Foreground="#E0E0E0" CaretBrush="#E0E0E0"
                                     BorderBrush="#2D2D2D" BorderThickness="1"
                                     Padding="6,3,4,3" VerticalContentAlignment="Center"
                                     TextChanged="RightParentFoldersSearch_TextChanged"/>
                            <TextBlock x:Name="RightParentFoldersSearchPlaceholder" Text="search…"
                                       Foreground="#666666" Margin="8,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>

                        <!-- ListBox -->
                        <ListBox x:Name="RightParentFoldersList" Grid.Row="2"
                                 Style="{StaticResource ModernListBox}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectedItem="{Binding SelectedParentFolder}"
                                 KeyDown="List_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" Margin="{DynamicResource RowCellMargin}">
                                        <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="#E0E0E0"/>
                                        <TextBox x:Name="NameEdit"
                                                 Text="{Binding Name, UpdateSourceTrigger=Explicit}"
                                                 Background="#121212"
                                                 Foreground="#E0E0E0"
                                                 BorderBrush="#007ACC"
                                                 BorderThickness="1"
                                                 Padding="2,1"
                                                 Margin="-2,-2,-2,-2"
                                                 Visibility="Collapsed"
                                                 LostFocus="NameEdit_LostFocus"
                                                 KeyDown="NameEdit_KeyDown"
                                                 IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Overlay Placeholder for Inactive Right Pane -->
            <Border Grid.Row="0" Grid.RowSpan="2" 
                    x:Name="RightPaneOverlay"
                    Background="#161616"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    CornerRadius="3"
                    Cursor="Hand"
                    MouseDown="RightPaneOverlay_MouseDown">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Right Pane Inactive" Foreground="#D4D4D4" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Click anywhere in this pane to activate" Foreground="#858585" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Grid>
</Window>
