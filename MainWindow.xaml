<Window x:Class="Filey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Filey"
        mc:Ignorable="d"
        Title="Filey — Dual Pane File Manager" Height="787" Width="1555"
        Background="#121212"
        Foreground="#E0E0E0">
    <Window.Resources>
        <!-- Row density values, swapped at runtime by the Compact Mode toggle. -->
        <Thickness x:Key="RowItemPadding">4,4,4,4</Thickness>
        <Thickness x:Key="RowCellMargin">2</Thickness>

        <!-- Shared right-click context menu for all folder/file/bookmark items in MainWindow (e.g. Favourites) -->
        <ContextMenu x:Key="ItemContextMenu" Opened="ItemContextMenu_Opened">
            <MenuItem Header="Open in Windows Explorer" Click="CtxOpenExplorer_Click"/>
            <MenuItem Header="Copy path to clipboard" Click="CtxCopyPath_Click"/>
            <MenuItem x:Name="CtxFavouriteItem" Header="Add to Favourites" Click="CtxToggleFavourite_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Menu Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Pane Layout -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Global Top Menu Bar: slim container for toggles/buttons added in later patches -->
        <Border x:Name="TopMenuBar"
                Grid.Row="0"
                Background="#1B1B1B"
                BorderBrush="#2D2D2D"
                BorderThickness="0,0,0,1"
                Height="28">
            <StackPanel x:Name="TopMenuBarItems"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="6,0">
                <ToggleButton x:Name="RightPaneToggle"
                              Style="{StaticResource TopBarToggleStyle}"
                              Content="Right Pane"
                              ToolTip="Show or hide the right pane"
                              IsChecked="True"
                              Checked="RightPaneToggle_Changed"
                              Unchecked="RightPaneToggle_Changed"/>
                <ToggleButton x:Name="ShowHiddenToggle"
                              Style="{StaticResource TopBarToggleStyle}"
                              Content="Hidden"
                              ToolTip="Show or hide hidden and system items"
                              Checked="ShowHiddenToggle_Changed"
                              Unchecked="ShowHiddenToggle_Changed"/>
                <ToggleButton x:Name="CompactModeToggle"
                              Style="{StaticResource TopBarToggleStyle}"
                              Content="Compact"
                              ToolTip="Reduce row spacing in the file lists"
                              Checked="CompactModeToggle_Changed"
                              Unchecked="CompactModeToggle_Changed"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <!-- Col 0: Favourites L -->
                <ColumnDefinition x:Name="LeftFavouritesCol" Width="150" MinWidth="50"/>
                <!-- Divider 1 -->
                <ColumnDefinition Width="4" />
                <!-- Col 2: Left Side Pane -->
                <ColumnDefinition x:Name="LeftPaneCol" Width="1000" MinWidth="200" />
                <!-- Centre Splitter -->
                <ColumnDefinition x:Name="CentreSplitterCol" Width="12" />
                <!-- Col 4: Right Side Pane -->
                <ColumnDefinition x:Name="RightPaneCol" Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Favourites panel on the far left -->
            <local:FavouritesPanel x:Name="LeftFavouritesPanel" Grid.Column="0" Side="Left"/>

            <!-- GridSplitter between Favourites and Left Pane -->
            <GridSplitter Grid.Column="1" Style="{StaticResource ModernGridSplitter}" />

            <!-- Left Directory Pane -->
            <local:DirectoryPane x:Name="LeftDirectoryPane" Grid.Column="2" ViewModel="{Binding LeftViewModel, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Side="Left" HomeRequested="LeftDirectoryPane_HomeRequested" SetHomeRequested="LeftDirectoryPane_SetHomeRequested"/>

            <!-- Centre Splitter between Left and Right Panes -->
            <GridSplitter x:Name="CentreSplitter" Grid.Column="3" Style="{StaticResource ModernGridSplitter}" Width="12" />

            <!-- Right Pane Grid (includes the DirectoryPane and the Inactive Overlay) -->
            <Grid x:Name="RightPaneGrid" Grid.Column="4" DataContext="{Binding RightViewModel, RelativeSource={RelativeSource AncestorType=local:MainWindow}}">
                <local:DirectoryPane x:Name="RightDirectoryPane" ViewModel="{Binding RightViewModel, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Side="Right" HomeRequested="RightDirectoryPane_HomeRequested" SetHomeRequested="RightDirectoryPane_SetHomeRequested"/>

                <!-- Overlay Placeholder for Inactive Right Pane -->
                <Border Grid.Row="0" Grid.RowSpan="2" 
                        x:Name="RightPaneOverlay"
                        Background="#161616"
                        BorderBrush="#2D2D2D"
                        BorderThickness="1"
                        CornerRadius="3"
                        Cursor="Hand"
                        MouseDown="RightPaneOverlay_MouseDown">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Right Pane Inactive" Foreground="#D4D4D4" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Click anywhere in this pane to activate" Foreground="#858585" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
