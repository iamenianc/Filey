<UserControl x:Class="Filey.FavouritesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Filey"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="150">
    <UserControl.Resources>
        <Style x:Key="FavFlatButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="FavTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FavListBox" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        </Style>

        <ContextMenu x:Key="FavItemContextMenu">
            <MenuItem
                Header="Open in Right Pane"
                Click="FavCtxOpenRightPane_Click" />
            <MenuItem Header="Open in Windows Explorer" Click="FavCtxOpenExplorer_Click"/>
            <MenuItem Header="Copy path to clipboard" Click="FavCtxCopyPath_Click"/>
            <MenuItem Header="Set group…" Click="FavCtxSetGroup_Click"/>
            <MenuItem Header="Clear group" Click="FavCtxClearGroup_Click"/>
            <MenuItem Header="Remove from Favourites" Click="FavCtxRemove_Click"/>
        </ContextMenu>

        <Style TargetType="ListBoxItem" x:Key="FavListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="{DynamicResource RowItemPadding}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- Group header style -->
        <Style x:Key="GroupHeaderStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppTextDimBrush}"
                                       FontSize="{DynamicResource SmallFontSize}" FontWeight="SemiBold"
                                       Margin="4,6,0,2"/>
                            <ItemsPresenter/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource AppPanelBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="3"
            AllowDrop="True"
            PreviewDragOver="Panel_DragOver"
            Drop="Panel_Drop">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Height="32"
                    Margin="-4,-4,-4,6"
                    Padding="8,0">
                <TextBlock Text="Favourites" Foreground="{DynamicResource AppTextSecondaryBrush}"
                           FontSize="{DynamicResource NormalFontSize}" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Bookmark list -->
            <ListBox x:Name="BookmarksList" Grid.Row="1"
                     Style="{StaticResource FavListBox}"
                     KeyDown="BookmarksList_KeyDown"
                     PreviewMouseLeftButtonDown="BookmarksList_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="BookmarksList_PreviewMouseMove"
                     PreviewMouseLeftButtonUp="BookmarksList_PreviewMouseLeftButtonUp">
                <ListBox.GroupStyle>
                    <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}"/>
                </ListBox.GroupStyle>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource FavListBoxItem}">
                        <Setter Property="ContextMenu" Value="{StaticResource FavItemContextMenu}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <TextBlock x:Name="NameText" Text="{Binding Name}" Foreground="{DynamicResource AppTextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBox x:Name="NameEdit"
                                     Text="{Binding Name, UpdateSourceTrigger=Explicit}"
                                     Background="{DynamicResource AppPanelDeepBrush}" Foreground="{DynamicResource AppTextPrimaryBrush}"
                                     BorderBrush="{DynamicResource AppAccentBrush}" BorderThickness="1" Padding="2,1"
                                     Margin="-2" Visibility="Collapsed"
                                     LostFocus="NameEdit_LostFocus"
                                     KeyDown="NameEdit_KeyDown"
                                     IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Drives group -->
            <StackPanel Grid.Row="2" x:Name="DrivesSection" Margin="0,6,0,0">
                <Border BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,4"/>
                <TextBlock Text="DRIVES" Foreground="{DynamicResource AppTextDimBrush}"
                           FontSize="{DynamicResource SmallFontSize}" FontWeight="SemiBold" Margin="2,0,0,4"/>
                <ItemsControl x:Name="DrivesList" FontSize="{DynamicResource AppFontSize}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="{DynamicResource RowItemPadding}" Background="Transparent"
                                    Cursor="Hand" MouseLeftButtonUp="Drive_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AppHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Add button -->
            <Button x:Name="AddButton" Grid.Row="3" Style="{StaticResource FavFlatButton}" Margin="0,6,0,0"
                    HorizontalAlignment="Stretch" Content="+ Add" Click="AddButton_Click"/>

            <!-- Set-group popup -->
            <Popup x:Name="GroupPopup" Grid.Row="3" Placement="Top"
                   PlacementTarget="{Binding ElementName=AddButton}" StaysOpen="False"
                   AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="10" Width="200">
                    <StackPanel>
                        <TextBlock Text="Set group" Foreground="{DynamicResource AppTextPrimaryBrush}"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="GroupNameBox" Style="{StaticResource FavTextBox}" Margin="0,2,0,10"
                                 KeyDown="GroupNameBox_KeyDown"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource FavFlatButton}" Content="Cancel"
                                    Margin="0,0,6,0" Click="GroupPopupCancel_Click"/>
                            <Button Style="{StaticResource FavFlatButton}" Content="Set"
                                    Foreground="{DynamicResource AppSuccessBrush}" Click="GroupPopupConfirm_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
