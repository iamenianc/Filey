<UserControl
    x:Class="Filey.PreviewPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Filey"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="400"
    Background="#1E1E1E"
    Foreground="#E0E0E0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Mode 1: Text Viewer -->
        <TextBox
            x:Name="ContentTextBox"
            Grid.Row="0"
            Visibility="Collapsed"
            Background="#1E1E1E"
            Foreground="#D4D4D4"
            BorderThickness="0"
            FontFamily="Consolas"
            FontSize="12"
            Padding="10"
            IsReadOnly="True"
            AcceptsReturn="True"
            AcceptsTab="True"
            TextWrapping="Wrap"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            CaretBrush="#E0E0E0"
            SelectionBrush="#094771"
            PreviewMouseWheel="ContentTextBox_PreviewMouseWheel" />

        <!-- Mode 2: Image Viewer -->
        <ScrollViewer
            x:Name="ImageScrollViewer"
            Grid.Row="0"
            Visibility="Collapsed"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Background="#1E1E1E"
            PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
            <Grid
                x:Name="ImageGrid"
                Background="Transparent"
                ClipToBounds="True"
                MouseLeftButtonDown="ImageGrid_MouseLeftButtonDown"
                MouseLeftButtonUp="ImageGrid_MouseLeftButtonUp"
                MouseMove="ImageGrid_MouseMove">
                <Image
                    x:Name="ContentImage"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.LayoutTransform>
                        <TransformGroup>
                            <ScaleTransform
                                x:Name="ImageScale" />
                            <RotateTransform
                                x:Name="ImageRotation" />
                        </TransformGroup>
                    </Image.LayoutTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Mode 3: Empty State / Non-Supported File Indicator -->
        <Border
            x:Name="EmptyStateBorder"
            Grid.Row="0"
            Background="#1E1E1E"
            Visibility="Visible">
            <StackPanel
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="20">
                <TextBlock
                    x:Name="EmptyStateMainText"
                    Text="Select a file to preview"
                    Foreground="#858585"
                    FontSize="13"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="EmptyStateSubText"
                    Text="Support for text, code files, and images"
                    Foreground="#555555"
                    FontSize="11"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Mode 4: Folder Viewer -->
        <ScrollViewer
            x:Name="FolderScrollViewer"
            Grid.Row="0"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Background="#1E1E1E"
            Padding="16"
            Visibility="Collapsed"
            PreviewMouseWheel="FolderScrollViewer_PreviewMouseWheel"
            ScrollChanged="FolderScrollViewer_ScrollChanged">
            <local:FastTreeVisualHost
                x:Name="FolderTreeVisualHost"
                HorizontalAlignment="Left"
                VerticalAlignment="Top" />
        </ScrollViewer>

        <!-- Mode 5: PDF Viewer -->
        <Grid
            x:Name="PdfViewerGrid"
            Grid.Row="0"
            Visibility="Collapsed">
            <!-- Preview State: 2x2 Grid for the first 4 pages -->
            <Grid
                x:Name="PdfSkimGrid"
                Visibility="Visible"
                Focusable="True"
                MouseDown="PdfSkimGrid_MouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition
                        Height="*" />
                    <RowDefinition
                        Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="4"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    Background="#161616">
                    <Image
                        x:Name="PdfSkimImage0"
                        Stretch="Uniform"
                        RenderOptions.BitmapScalingMode="LowQuality" />
                </Border>
                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="4"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    Background="#161616">
                    <Image
                        x:Name="PdfSkimImage1"
                        Stretch="Uniform"
                        RenderOptions.BitmapScalingMode="LowQuality" />
                </Border>
                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="4"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    Background="#161616">
                    <Image
                        x:Name="PdfSkimImage2"
                        Stretch="Uniform"
                        RenderOptions.BitmapScalingMode="LowQuality" />
                </Border>
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="4"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    Background="#161616">
                    <Image
                        x:Name="PdfSkimImage3"
                        Stretch="Uniform"
                        RenderOptions.BitmapScalingMode="LowQuality" />
                </Border>

                <!-- Overlay prompt -->
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.RowSpan="2"
                    Grid.ColumnSpan="2"
                    Background="#B00C0C0C"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="16"
                    Padding="12,6"
                    IsHitTestVisible="False">
                    <TextBlock
                        Text="🖱️ Double-click to open in full preview window"
                        Foreground="#CCCCCC"
                        FontSize="11"
                        FontWeight="SemiBold" />
                </Border>
            </Grid>

            <!-- Active State: Full scroll viewer -->
            <ScrollViewer
                x:Name="PdfActiveViewer"
                Visibility="Collapsed"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                ScrollChanged="PdfActiveViewer_ScrollChanged"
                SizeChanged="PdfActiveViewer_SizeChanged">
                <ItemsControl
                    x:Name="PdfPageItemsControl"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="8,12"
                                BorderBrush="#2D2D2D"
                                BorderThickness="1"
                                Background="#1E1E1E"
                                Width="{Binding DisplayWidth}"
                                Height="{Binding DisplayHeight}"
                                HorizontalAlignment="Center">
                                <Grid>
                                    <TextBlock
                                        Text="Loading..."
                                        Foreground="#555555"
                                        FontSize="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style
                                                TargetType="TextBlock">
                                                <Setter
                                                    Property="Visibility"
                                                    Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding Image}"
                                                        Value="{x:Null}">
                                                        <Setter
                                                            Property="Visibility"
                                                            Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Image
                                        Source="{Binding Image}"
                                        Stretch="Uniform"
                                        RenderOptions.BitmapScalingMode="HighQuality" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>


        <!-- Subtle Scroll Reminder Prompt -->
        <TextBlock
            x:Name="ScrollPromptTextBlock"
            Grid.Row="0"
            Text="Ctrl + Scroll Wheel to adjust folder depth"
            Foreground="#475569"
            FontSize="12"
            FontStyle="Italic"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,8,24,0"
            IsHitTestVisible="False"
            Visibility="Collapsed" />

        <!-- Status Bar -->
        <Border
            Grid.Row="1"
            Background="#1B1B1B"
            BorderBrush="#2D2D2D"
            BorderThickness="0,1,0,0"
            Height="24"
            Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PathTextBlock"
                    Grid.Column="0"
                    Foreground="#858585"
                    FontSize="10"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <StackPanel
                    x:Name="DepthSelectorPanel"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0"
                    Visibility="Collapsed">
                    <TextBlock
                        Text="Depth: "
                        Foreground="#858585"
                        FontSize="10"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="DepthButton1"
                        Content="L1"
                        Click="DepthButton_Click"
                        Tag="1"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton2"
                        Content="L2"
                        Click="DepthButton_Click"
                        Tag="2"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton3"
                        Content="L3"
                        Click="DepthButton_Click"
                        Tag="3"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton4"
                        Content="L4"
                        Click="DepthButton_Click"
                        Tag="4"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton5"
                        Content="L5"
                        Click="DepthButton_Click"
                        Tag="5"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton6"
                        Content="L6"
                        Click="DepthButton_Click"
                        Tag="6"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton7"
                        Content="L7"
                        Click="DepthButton_Click"
                        Tag="7"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton8"
                        Content="L8"
                        Click="DepthButton_Click"
                        Tag="8"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton9"
                        Content="L9"
                        Click="DepthButton_Click"
                        Tag="9"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton10"
                        Content="L10"
                        Click="DepthButton_Click"
                        Tag="10"
                        Style="{StaticResource DepthButtonStyle}" />
                </StackPanel>

                <TextBlock
                    x:Name="EncodingTextBlock"
                    Grid.Column="2"
                    Foreground="#858585"
                    FontSize="10"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0" />

                <TextBlock
                    x:Name="SizeTextBlock"
                    Grid.Column="3"
                    Foreground="#858585"
                    FontSize="10"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0" />

                <Button
                    x:Name="PopOutButton"
                    Grid.Column="4"
                    Content="↗ Pop Out"
                    Click="PopOutButton_Click"
                    Foreground="#A0A0A0"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="10"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0"
                    Cursor="Hand"
                    ToolTip="Open in separate window"
                    Style="{StaticResource FlatButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
