<UserControl
    x:Class="Filey.PreviewPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Filey"
    xmlns:previews="clr-namespace:Filey.Previews"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="400"
    Background="{DynamicResource AppPanelBackgroundBrush}"
    Foreground="{DynamicResource AppTextPrimaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Preview Hosts -->
        <Grid Grid.Row="0">
            <!-- Mode 1: Text Viewer -->
            <previews:TextPreview
                x:Name="TextPreviewControl"
                Visibility="Collapsed" />

            <!-- Mode 2: Image Viewer -->
            <previews:ImagePreview
                x:Name="ImagePreviewControl"
                Visibility="Collapsed" />

            <!-- Mode 3: Empty State / Non-Supported File Indicator -->
            <Border
                x:Name="EmptyStateBorder"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                Visibility="Visible">
                <StackPanel
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="20">
                    <TextBlock
                        x:Name="EmptyStateMainText"
                        Text="Select a file to preview"
                        Foreground="{DynamicResource AppTextMutedBrush}"
                        FontSize="{DynamicResource NormalFontSize}"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="EmptyStateSubText"
                        Text="Support for text, code files, and images"
                        Foreground="{DynamicResource AppTextDimBrush}"
                        FontSize="{DynamicResource HeaderFontSize}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Mode 4: Folder Viewer -->
            <previews:FolderPreview
                x:Name="FolderPreviewControl"
                Visibility="Collapsed" />

            <!-- Mode 5: PDF Viewer -->
            <previews:PdfPreview
                x:Name="PdfPreviewControl"
                Visibility="Collapsed" />

            <!-- Mode 6: Markdown / Web Viewer -->
            <previews:MarkdownPreview
                x:Name="MarkdownPreviewControl"
                Visibility="Collapsed" />

            <!-- Mode 7: Spreadsheet Viewer -->
            <previews:ExcelPreview
                x:Name="ExcelPreviewControl"
                Visibility="Collapsed" />

            <!-- Subtle Scroll Reminder Prompt -->
            <TextBlock
                x:Name="ScrollPromptTextBlock"
                Text="Ctrl + Scroll Wheel to adjust folder depth"
                Foreground="{DynamicResource AppTextDimBrush}"
                FontSize="{DynamicResource NormalFontSize}"
                FontStyle="Italic"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,24,0"
                IsHitTestVisible="False"
                Visibility="Collapsed" />
        </Grid>

        <!-- Status Bar -->
        <Border
            x:Name="PaneStatusBar"
            Grid.Row="1"
            Background="{DynamicResource AppTopBarBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="0,1,0,0"
            MinHeight="24"
            Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PathTextBlock"
                    Grid.Column="0"
                    Foreground="{DynamicResource AppTextMutedBrush}"
                    FontSize="{DynamicResource SmallFontSize}"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <StackPanel
                    x:Name="DepthSelectorPanel"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0"
                    Visibility="Collapsed">
                    <TextBlock
                        Text="Depth: "
                        Foreground="{DynamicResource AppTextMutedBrush}"
                        FontSize="{DynamicResource SmallFontSize}"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="DepthButton1"
                        Content="L1"
                        Click="DepthButton_Click"
                        Tag="1"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton2"
                        Content="L2"
                        Click="DepthButton_Click"
                        Tag="2"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton3"
                        Content="L3"
                        Click="DepthButton_Click"
                        Tag="3"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton4"
                        Content="L4"
                        Click="DepthButton_Click"
                        Tag="4"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton5"
                        Content="L5"
                        Click="DepthButton_Click"
                        Tag="5"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton6"
                        Content="L6"
                        Click="DepthButton_Click"
                        Tag="6"
                        Style="{StaticResource DepthButtonStyle}" />
                </StackPanel>

                <TextBlock
                    x:Name="EncodingTextBlock"
                    Grid.Column="2"
                    Foreground="{DynamicResource AppTextMutedBrush}"
                    FontSize="{DynamicResource SmallFontSize}"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0" />

                <TextBlock
                    x:Name="SizeTextBlock"
                    Grid.Column="3"
                    Foreground="{DynamicResource AppTextMutedBrush}"
                    FontSize="{DynamicResource SmallFontSize}"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0" />

                <Button
                    x:Name="PopOutButton"
                    Grid.Column="4"
                    Content="↗ Pop Out"
                    Click="PopOutButton_Click"
                    Foreground="{DynamicResource AppTextMutedBrush}"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="{DynamicResource SmallFontSize}"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0"
                    Cursor="Hand"
                    ToolTip="Open in separate window"
                    Style="{StaticResource FlatButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
