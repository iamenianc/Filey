<UserControl
    x:Class="Filey.PreviewPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Filey"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="400"
    Background="#1E1E1E"
    Foreground="#E0E0E0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Mode 1: Text Viewer -->
        <TextBox
            x:Name="ContentTextBox"
            Grid.Row="0"
            Visibility="Collapsed"
            Background="#1E1E1E"
            Foreground="#D4D4D4"
            BorderThickness="0"
            FontFamily="Consolas"
            FontSize="12"
            Padding="10"
            IsReadOnly="True"
            AcceptsReturn="True"
            AcceptsTab="True"
            TextWrapping="NoWrap"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            CaretBrush="#E0E0E0"
            SelectionBrush="#094771"
            PreviewMouseWheel="ContentTextBox_PreviewMouseWheel" />

        <!-- Mode 2: Image Viewer -->
        <ScrollViewer
            x:Name="ImageScrollViewer"
            Grid.Row="0"
            Visibility="Collapsed"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Background="#1E1E1E"
            PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
            <Grid
                x:Name="ImageGrid"
                Background="Transparent"
                ClipToBounds="True"
                MouseLeftButtonDown="ImageGrid_MouseLeftButtonDown"
                MouseLeftButtonUp="ImageGrid_MouseLeftButtonUp"
                MouseMove="ImageGrid_MouseMove">
                <Image
                    x:Name="ContentImage"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.LayoutTransform>
                        <TransformGroup>
                            <ScaleTransform
                                x:Name="ImageScale" />
                            <RotateTransform
                                x:Name="ImageRotation" />
                        </TransformGroup>
                    </Image.LayoutTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Mode 3: Empty State / Non-Supported File Indicator -->
        <Border
            x:Name="EmptyStateBorder"
            Grid.Row="0"
            Background="#1E1E1E"
            Visibility="Visible">
            <StackPanel
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="20">
                <TextBlock
                    x:Name="EmptyStateMainText"
                    Text="Select a file to preview"
                    Foreground="#858585"
                    FontSize="13"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="EmptyStateSubText"
                    Text="Support for text, code files, and images"
                    Foreground="#555555"
                    FontSize="11"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Mode 4: Folder Viewer -->
        <ScrollViewer
            x:Name="FolderScrollViewer"
            Grid.Row="0"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            Background="#1E1E1E"
            Padding="16"
            Visibility="Collapsed"
            PreviewMouseWheel="FolderScrollViewer_PreviewMouseWheel"
            ScrollChanged="FolderScrollViewer_ScrollChanged">
            <local:FastTreeVisualHost
                x:Name="FolderTreeVisualHost"
                HorizontalAlignment="Left"
                VerticalAlignment="Top" />
        </ScrollViewer>

        <!-- Subtle Scroll Reminder Prompt -->
        <TextBlock
            x:Name="ScrollPromptTextBlock"
            Grid.Row="0"
            Text="Ctrl + Scroll Wheel to adjust folder depth"
            Foreground="#475569"
            FontSize="12"
            FontStyle="Italic"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,8,24,0"
            IsHitTestVisible="False"
            Visibility="Collapsed" />

        <!-- Status Bar -->
        <Border
            Grid.Row="1"
            Background="#1B1B1B"
            BorderBrush="#2D2D2D"
            BorderThickness="0,1,0,0"
            Height="24"
            Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PathTextBlock"
                    Grid.Column="0"
                    Foreground="#858585"
                    FontSize="10"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <StackPanel
                    x:Name="DepthSelectorPanel"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0"
                    Visibility="Collapsed">
                    <TextBlock
                        Text="Depth: "
                        Foreground="#858585"
                        FontSize="10"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="DepthButton1"
                        Content="L1"
                        Click="DepthButton_Click"
                        Tag="1"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton2"
                        Content="L2"
                        Click="DepthButton_Click"
                        Tag="2"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton3"
                        Content="L3"
                        Click="DepthButton_Click"
                        Tag="3"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton4"
                        Content="L4"
                        Click="DepthButton_Click"
                        Tag="4"
                        Style="{StaticResource DepthButtonStyle}" />
                    <Button
                        x:Name="DepthButton5"
                        Content="L5"
                        Click="DepthButton_Click"
                        Tag="5"
                        Style="{StaticResource DepthButtonStyle}" />
                </StackPanel>

                <TextBlock
                    x:Name="EncodingTextBlock"
                    Grid.Column="2"
                    Foreground="#858585"
                    FontSize="10"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0" />

                <TextBlock
                    x:Name="SizeTextBlock"
                    Grid.Column="3"
                    Foreground="#858585"
                    FontSize="10"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
